    "background.editorBackgrounds": [],
    "background.backgroundAlignment": [
        "Center Center",
        "Center Center",
        "Center Center",
        "Center Center"
    ],
    "background.backgroundBlur": [
        "50",
        "100",
        "0",
        "0"
    ],
